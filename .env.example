# CC Verse — environment variables
# Copy to `.env` for local dev. NEVER commit a real `.env`.
# All values are validated at boot by `lib/env.ts`; the process crashes on
# missing or malformed values.

# ── App / Proxy ──────────────────────────────────────────────────────────────
# Public origin of the application (used for absolute URLs in emails, CORS, etc.).
APP_ORIGIN=http://localhost:3000
# Public origin behind the proxy (used in CSP and cookie scoping). Empty in
# local dev where the app is reached directly.
PROXY_ORIGIN=
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# `postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public`
DATABASE_URL=postgresql://ccverse:ccverse@localhost:5432/ccverse?schema=public

# ── Object storage (AWS S3) ──────────────────────────────────────────────────
S3_REGION=us-east-1
# The following access keys are DEV-ONLY. In production the server uses an
# instance role / IAM role; do not embed static keys in deployed envs.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: override the S3 endpoint (e.g. for MinIO in local dev).
S3_ENDPOINT=
# Force path-style addressing when using an S3-compatible mock.
S3_FORCE_PATH_STYLE=false
S3_BUCKET_KYC=ccverse-kyc
S3_BUCKET_PROJECTS=ccverse-projects
S3_BUCKET_CERTIFICATES=ccverse-certificates
S3_BUCKET_AUDIT_EXPORTS=ccverse-audit-exports

# ── Email (AWS SES) ──────────────────────────────────────────────────────────
SES_REGION=us-east-1
SES_SENDER_DOMAIN=ccverse.local
SES_CONFIGURATION_SET=ccverse-default
# Optional: dev-only static SES credentials. In production, use IAM role.
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=

# ── Session ──────────────────────────────────────────────────────────────────
# 32+ char random string. `openssl rand -base64 32` to generate.
SESSION_SECRET=replace-me-with-a-32-char-random-string-please

# ── Build metadata (injected at build time, optional in dev) ─────────────────
GIT_SHA=
BUILT_AT=
