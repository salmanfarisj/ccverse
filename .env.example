# CC Verse — environment variables
# Copy to `.env` for local dev. NEVER commit a real `.env`.
# Next.js boot validates app + session vars via `lib/env.ts`.
# Convex functions read their own env from the Convex deployment.

# ── App / Proxy ──────────────────────────────────────────────────────────────
APP_ORIGIN=http://localhost:3000
# Public origin behind the proxy (CSP, cookie scoping). Empty when reached directly.
PROXY_ORIGIN=
NODE_ENV=development

# ── Session ──────────────────────────────────────────────────────────────────
# 32+ char random string. `openssl rand -base64 32` to generate.
SESSION_SECRET=replace-me-with-a-32-char-random-string-please

# ── Convex (Next.js client) ──────────────────────────────────────────────────
# Set automatically by `convex dev` in `.env.local`:
#   NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3212
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
# Server-only fallback for lib/convex/client.ts (payment webhooks, etc.)
CONVEX_DEPLOYMENT_URL=
# Deploy key for CI/production deploys (Convex dashboard).
CONVEX_DEPLOY_KEY=

# ── Build metadata (injected at build time, optional in dev) ─────────────────
GIT_SHA=
BUILT_AT=

# ── Admin seed (Convex CLI — not read by Next.js) ────────────────────────────
#   npx convex run seed:seedAdminAction '{"email":"admin@ccverse.local","password":"change-me-locally-32-chars-min"}'
SEED_ADMIN_EMAIL=admin@ccverse.local
SEED_ADMIN_PASSWORD=change-me-locally-32-chars-min

# ── Optional Convex deployment env (set via `npx convex env set` or dashboard)
# Email and storage are mocked in dev when credentials are unset.
# SES_REGION=us-east-1
# SES_SENDER_DOMAIN=ccverse.local
# SES_CONFIGURATION_SET=
# SES_ACCESS_KEY_ID=
# SES_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_BUCKET=ccverse-storage
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false
