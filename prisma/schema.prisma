// CC Verse — Prisma schema (Phase 0).
//
// Source of truth for the data model. The phase-0 plan (T0-3) creates
// *all* FRD §6 tables now so subsequent migrations are additive only.
// Each table starts with the minimum columns required by §5 of
// `docs/phases/phase-0-foundation.md`; full column sets are added in
// the owning phase (2, 3, 4, …) via `prisma migrate dev`.
//
// Architectural invariants encoded here (see `docs/plan.md` §7 and
// `docs/phases/phase-0-foundation.md` §4.3, §4.6, §4.8):
//
//   - `User.email` is `Citext` so case-insensitive uniqueness holds
//     even if an upstream client sends `Foo@x.com` vs `foo@x.com`.
//   - `RegistryEntry.cvcSerial` is `UNIQUE` — the registry is the
//     single source of truth and serials never duplicate.
//   - `AuditLog.payload` is JSONB and the model is append-only by
//     convention (no `updatedAt`, no UPDATE path in `lib/audit/`).
//   - IDs are `uuid()`-generated application-side; no DB extension
//     dependency for primary keys.

generator client {
  provider      = "prisma-client-js"
  // `native` covers the local dev box (macOS arm64, glibc, musl);
  // `linux-musl-openssl-3.0.x` covers CI (ubuntu-latest) and the
  // Aliyun/Railway musl images we plan to deploy onto. Add more
  // targets here if a new deploy target appears.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum UserRole {
  BUYER
  SELLER
  AUDITOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum KycDocumentType {
  PAN
  GSTIN
  PASSPORT
  UTILITY_BILL
  BANK_STATEMENT
  INCORPORATION_CERT
  OTHER
}

enum KycDocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BuyerKycStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum BuyerKycMethod {
  NONE
  MANUAL
}

enum DefaultCurrency {
  INR
  USD
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ACTIVE
  RETIRED
}

enum ListingStatus {
  DRAFT
  PENDING_AUDIT
  ACTIVE
  SOLD_OUT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  REFUNDED
  CANCELLED
}

enum PaymentStatus {
  INITIATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum CertificateStatus {
  PENDING
  ISSUED
  REVOKED
}

enum AuditDecisionStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum RegistryState {
  AVAILABLE
  HELD
  RETIRED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REVERSED
}

// ─── Models ───────────────────────────────────────────────────────────────

/// A registered user. Roles and statuses are enum-bounded; an
/// unauthenticated visitor is represented by the *absence* of a User
/// row (i.e. no session) — `public` is not a role value. The single
/// admin row is created by `prisma/seed.ts`.
model User {
  id               String      @id @default(uuid())
  // Case-insensitive uniqueness via the PostgreSQL `citext` extension.
  // Prisma 5+ emits `CREATE EXTENSION IF NOT EXISTS citext;` in the
  // generated migration automatically when it sees `@db.Citext`.
  email            String      @unique @db.Citext
  passwordHash     String?     @map("password_hash")
  role             UserRole    @default(BUYER)
  status           UserStatus  @default(PENDING_VERIFICATION)
  mfaEnabled       Boolean     @default(false) @map("mfa_enabled")
  emailVerified    Boolean     @default(false) @map("email_verified")
  emailVerifiedAt  DateTime?   @map("email_verified_at")
  failedLoginCount Int         @default(0) @map("failed_login_count")
  lockedUntil      DateTime?   @map("locked_until")
  lastLoginAt      DateTime?   @map("last_login_at")
  lastLoginIp      String?     @map("last_login_ip") // inet in PG, stored as String
  createdAt        DateTime    @default(now()) @map("created_at")

  // Relations
  sellerProfile    SellerProfile?
  buyerProfile     BuyerProfile?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  kycDocuments            KycDocument[] @relation("SubjectUser")
  kycDocumentsUploaded    KycDocument[] @relation("UploadedBy")
  bankAccounts            BankAccount[]

  @@map("user")
}

/// Seller-side profile (1:1 with User). Final schema lands in Phase 2.
model SellerProfile {
  id                       String   @id @default(uuid())
  userId                   String   @unique @map("user_id")
  legalName                String?  @map("legal_name")
  registrationNo           String?  @map("registration_no")
  country                  String?
  authorizedSignatoryName  String?  @map("authorized_signatory_name")
  authorizedSignatoryEmail String?  @map("authorized_signatory_email")
  kycStatus                KycStatus @default(NOT_STARTED) @map("kyc_status")
  kycMethod                String   @default("manual") @map("kyc_method")
  kycReviewedBy           String?  @map("kyc_reviewed_by")
  kycReviewedAt            DateTime? @map("kyc_reviewed_at")
  kycReviewNotes           String?  @map("kyc_review_notes")
  bankAccountId            String?  @unique @map("bank_account_id")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  // Relations
  user        User        @relation(fields: [userId], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@map("seller_profile")
}

/// Buyer-side profile (1:1 with User). Final schema lands in Phase 1.
model BuyerProfile {
  id              String          @id @default(uuid())
  userId          String          @unique @map("user_id")
  legalName       String?         @map("legal_name")
  country         String?
  kycStatus       BuyerKycStatus @default(NOT_REQUIRED) @map("kyc_status")
  kycMethod       BuyerKycMethod  @default(NONE) @map("kyc_method")
  defaultCurrency DefaultCurrency @default(USD) @map("default_currency")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("buyer_profile")
}

/// A KYC document uploaded by a seller during the onboarding wizard.
model KycDocument {
  id             String                   @id @default(uuid())
  subjectUserId  String                   @map("subject_user_id")
  documentType   KycDocumentType          @map("document_type")
  s3Key          String                   @map("s3_key")
  sha256         String?
  uploadedAt     DateTime                 @default(now()) @map("uploaded_at")
  uploadedById  String                   @map("uploaded_by")
  reviewStatus  KycDocumentReviewStatus  @default(PENDING) @map("review_status")
  reviewedBy    String?                  @map("reviewed_by")
  reviewedAt    DateTime?                @map("reviewed_at")
  reviewNotes   String?                  @map("review_notes")

  // Relations
  subjectUser User @relation("SubjectUser", fields: [subjectUserId], references: [id])
  uploader    User @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@map("kyc_document")
}

/// A seller's bank account for T+2 payouts.
model BankAccount {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  accountHolder   String    @map("account_holder")
  bankName        String    @map("bank_name")
  accountNoLast4  String    @map("account_no_last4")
  routingOrIfsc   String    @map("routing_or_ifsc")
  verified        Boolean   @default(false)
  verifiedAt      DateTime? @map("verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  user          User            @relation(fields: [userId], references: [id])
  sellerProfile SellerProfile?

  @@map("bank_account")
}

/// One-time email verification token for new user activation.
model EmailVerificationToken {
  token     String    @id
  userId    String    @map("user_id")
  expiresAt DateTime @map("expires_at")
  consumedAt DateTime? @map("consumed_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("email_verification_token")
}

/// One-time password reset token.
model PasswordResetToken {
  token     String    @id
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  ip        String?

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("password_reset_token")
}

/// A registered carbon-reduction project. Full schema lands in
/// Phase 2 (Project Registration & CVC Registry).
model Project {
  id        String        @id @default(uuid())
  status    ProjectStatus @default(DRAFT)
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("project")
}

/// A formal project registration record. Full schema in Phase 2.
model ProjectRegistration {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  @@map("project_registration")
}

/// A tradeable listing of registry entries. Full schema in Phase 3.
model Listing {
  id        String        @id @default(uuid())
  status    ListingStatus @default(DRAFT)
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("listing")
}

/// A buyer's purchase intent and the post-payment lifecycle.
model Order {
  id        String      @id @default(uuid())
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("order")
}

/// A payment record, one per Order. Phase 6.
model Payment {
  id        String        @id @default(uuid())
  status    PaymentStatus @default(INITIATED)
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("payment")
}

/// A signed certificate of ownership / retirement. Phase 7.
model Certificate {
  id        String            @id @default(uuid())
  status    CertificateStatus @default(PENDING)
  createdAt DateTime          @default(now()) @map("created_at")

  @@map("certificate")
}

/// An auditor's decision on a project or listing. Phase 4.
model AuditDecision {
  id        String              @id @default(uuid())
  status    AuditDecisionStatus @default(PENDING)
  createdAt DateTime            @default(now()) @map("created_at")

  @@map("audit_decision")
}

/// A dispute raised by a buyer or seller. Phase 8.
model Dispute {
  id        String        @id @default(uuid())
  status    DisputeStatus @default(OPEN)
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("dispute")
}

/// One row per Verified Carbon Credit serial. The `cvcSerial` unique
/// constraint is the architectural invariant from `docs/plan.md` §7:
/// no two rows may share a serial, ever. The registry is the *only*
/// place that creates or transitions these rows (via `lib/registry/`
/// in Phase 2).
model RegistryEntry {
  id        String        @id @default(uuid())
  state     RegistryState @default(AVAILABLE)
  cvcSerial String        @unique @map("cvc_serial")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([state])
  @@map("registry_entry")
}

/// A batch of CVCs allocated to a Seller against a Project. Phase 2.
model CvcBatch {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  @@map("cvc_batch")
}

/// Append-only audit trail. Every state-changing action across the
/// app writes a row here via `lib/audit/`. There is intentionally no
/// `updatedAt` — the table is append-only by convention (a 7-year
/// retention is enforced by `audit_log_retention_days` in
/// `PlatformConfig`).
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actorRole  String?  @map("actor_role")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  ip         String?
  timestamp  DateTime @default(now())
  payload    Json     @default("{}")

  @@index([actorId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_log")
}

/// A payout to a Seller. Phase 9.
model Payout {
  id        String       @id @default(uuid())
  status    PayoutStatus @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("payout")
}

/// Singleton-by-convention configuration table. The `key` column is
/// the primary key; the seed inserts a fixed set of default keys.
/// All callers should read via `lib/registry/` or a thin helper that
/// falls back to defaults — never assume a key exists without
/// handling the missing-key case.
model PlatformConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_config")
}

/// A job that exhausted its retry budget. Surfaces in the Admin
/// console for manual replay. The job *runner* itself (T0-4) writes
/// here on terminal failure.
model FailedJob {
  id        String   @id @default(uuid())
  jobType   String   @map("job_type")
  payload   Json
  error     String
  attempts  Int
  createdAt DateTime @default(now()) @map("created_at")
  failedAt  DateTime @default(now()) @map("failed_at")

  @@index([failedAt])
  @@map("failed_job")
}
